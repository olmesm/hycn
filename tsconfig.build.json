{
	"extends": "./tsconfig.app.json",
	"compilerOptions": {
		"allowImportingTsExtensions": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"noEmit": false,
		"outDir": "./dist",
		"rootDir": "./src",
		"sourceMap": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo"
	},
	"include": [
		"src/components/**/*.ts",
		"src/components/**/*.tsx",
		"src/utils/**/*.ts",
		"src/index.ts",
		"src/register.ts"
	],
	"exclude": ["src/stories", "src/globals.d.ts"]
}
