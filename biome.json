{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"files": {
		"includes": [
			"**",
			"!!build",
			"!!dist",
			"!!node_modules",
			"!!playwright-report",
			"!!test-results",
			"!!src/globals.d.ts"
		]
	}
}
